---
import Base from '../layouts/Base.astro';
import TopBar from '../components/TopBar.astro';
import Section from '../components/Section.astro';
import Timeline from '../components/Timeline.astro';
import EducationTimeline from '../components/EducationTimeline.astro';
import SkillMatrix from '../components/SkillMatrix.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const cvEntry = await getEntry('cv', 'data');
if (!cvEntry) throw new Error('cv/data entry not found');
const { experience, education, skills } = cvEntry.data;
---
<Base title="Andreas Knöfel – Lebenslauf">
  <a href="#main" class="skip-link">Zum Inhalt springen</a>
  <div class="page">
    <TopBar />
    <main id="main">
      <section id="stationen" class="stations">
        <h2 class="sr-only">Stationen</h2>
        <Timeline entries={experience} />
      </section>
      <Section label="Studium" id="studium">
        <EducationTimeline entries={education} />
      </Section>
      <Section label="Skills" id="skills">
        <SkillMatrix skills={skills} />
      </Section>
    </main>
    <Footer />
  </div>
</Base>
