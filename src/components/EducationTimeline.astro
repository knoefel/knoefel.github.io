---
import { formatRange } from '../lib/formatDate';
import Badge from './Badge.astro';

interface Degree {
  institution: string; location: string;
  from: string; to: string;
  degree: string; grade: string; thesis: string;
}
interface Props { entries: Degree[]; }
const { entries } = Astro.props;
---
<ol class="timeline">
  {entries.map(d => {
    const dateRange = formatRange(d.from, d.to);
    const fromYear = d.from.split('-')[0];
    return (
      <li class="entry">
        <div class="entry-year"><time datetime={d.from}>{fromYear}</time></div>
        <div class="entry-dot" aria-hidden="true"></div>
        <div class="entry-content">
          <h3 class="entry-company">{d.institution}</h3>
          <p class="entry-meta">{d.location} · {dateRange}</p>
          <p class="entry-title">{d.degree}</p>
          <p class="entry-grade-line">
            <Badge variant="outline">Note {d.grade}</Badge>
          </p>
          <p class="entry-thesis">
            <span class="entry-thesis-label">Bachelorarbeit</span>
            {d.thesis}
          </p>
        </div>
      </li>
    );
  })}
</ol>

<style>
  .timeline { list-style: none; padding: 0; margin: 0; position: relative; }
  .timeline::before {
    content: '';
    position: absolute;
    left: var(--timeline-line-x);
    top: 6px;
    bottom: 6px;
    width: 1px;
    background: var(--color-rule);
  }
  .entry {
    display: grid;
    grid-template-columns: var(--year-col-width) minmax(0, 1fr);
    column-gap: var(--timeline-column-gap);
    position: relative;
    padding-bottom: var(--space-8);
  }
  .entry:last-child { padding-bottom: 0; }
  .entry-year {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-muted);
    letter-spacing: 0.04em;
    padding-top: 2px;
    text-align: right;
    padding-right: var(--space-3);
    font-variant-numeric: tabular-nums;
  }
  .entry-dot {
    position: absolute;
    left: calc(var(--timeline-line-x) - var(--timeline-dot-size) / 2);
    top: 6px;
    width: var(--timeline-dot-size);
    height: var(--timeline-dot-size);
    border-radius: 50%;
    background: var(--color-bg);
    box-shadow: inset 0 0 0 2px var(--color-muted);
  }
  .entry-content { padding-left: var(--space-5); min-width: 0; }
  .entry-company {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: -0.015em;
    margin: 0 0 var(--space-2);
    overflow-wrap: break-word;
  }
  .entry-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
    overflow-wrap: break-word;
  }
  .entry-title {
    font-size: var(--text-md);
    font-weight: 500;
    color: var(--color-text);
    margin: var(--space-3) 0 var(--space-3);
    font-style: italic;
    overflow-wrap: break-word;
  }
  .entry-grade-line { margin: 0 0 var(--space-4); }
  .entry-thesis {
    font-size: var(--text-base);
    color: var(--color-text);
    max-width: 60ch;
    margin: 0;
    overflow-wrap: break-word;
  }
  .entry-thesis-label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  @media (max-width: 640px) {
    .entry-content { padding-left: var(--space-3); }
    .entry-company { font-size: var(--text-lg); }
  }

  @media (max-width: 480px) {
    .entry {
      grid-template-columns: 1fr;
      column-gap: 0;
      padding-bottom: var(--space-7);
    }
    .entry-year {
      text-align: left;
      padding: 0 0 var(--space-2) 0;
      font-size: var(--text-xs);
    }
    .entry-dot { display: none; }
    .entry-content { padding-left: 0; }
    .timeline::before { display: none; }
  }
</style>
