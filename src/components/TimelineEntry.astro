---
import { formatRange } from '../lib/formatDate';
import Badge from './Badge.astro';

interface Role {
  company: string; location: string;
  from: string; to: string | null;
  title: string; current?: boolean;
  summary: string; projects?: string[];
  responsibilities: string[]; stack: string[];
}
interface Props { role: Role; }
const { role } = Astro.props;
const dateRange = formatRange(role.from, role.to);
const fromYear = role.from.split('-')[0];
---
<li class:list={['entry', { 'entry--current': role.current === true }]}>
  <div class="entry-year">
    <time datetime={role.from}>{fromYear}</time>
  </div>
  <div class="entry-dot" aria-hidden="true"></div>
  <div class="entry-content">
    <header class="entry-head">
      <h3 class="entry-company">{role.company}</h3>
      <p class="entry-meta">{role.location} · {dateRange}</p>
      <p class="entry-title">{role.title}</p>
    </header>

    <p class="entry-summary">{role.summary}</p>

    {role.projects && role.projects.length > 0 && (
      <ul class="entry-list">
        {role.projects.map(p => <li><span class="bullet">&#9658;</span>{p}</li>)}
      </ul>
    )}

    <ul class="entry-list">
      {role.responsibilities.map(r => <li><span class="bullet">&mdash;</span>{r}</li>)}
    </ul>

    <div class="entry-stack">
      {role.stack.map(tag => <Badge variant="default">{tag}</Badge>)}
    </div>
  </div>
</li>

<style>
  .entry {
    display: grid;
    grid-template-columns: var(--year-col-width) minmax(0, 1fr);
    column-gap: var(--timeline-column-gap);
    position: relative;
    padding-bottom: var(--space-8);
  }
  .entry:last-child { padding-bottom: 0; }

  .entry-year {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-muted);
    letter-spacing: 0.04em;
    padding-top: 2px;
    text-align: right;
    padding-right: var(--space-3);
    font-variant-numeric: tabular-nums;
  }

  /* Dot positioned ON the vertical line */
  .entry-dot {
    position: absolute;
    left: calc(var(--timeline-line-x) - var(--timeline-dot-size) / 2);
    top: 6px;
    width: var(--timeline-dot-size);
    height: var(--timeline-dot-size);
    border-radius: 50%;
    background: var(--color-bg);
    box-shadow: inset 0 0 0 2px var(--color-muted);
  }
  .entry--current .entry-dot {
    background: var(--color-accent);
    box-shadow: 0 0 0 4px var(--color-accent-soft);
  }
  .entry--current .entry-year { color: var(--color-accent); }

  .entry-content {
    padding-left: var(--space-5);
    min-width: 0;           /* allow grid item to shrink below intrinsic content size */
  }

  .entry-company {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: -0.015em;
    margin: 0 0 var(--space-2);
    overflow-wrap: break-word;
  }
  .entry--current .entry-company { color: var(--color-accent); }

  .entry-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
    font-variant-numeric: tabular-nums;
    overflow-wrap: break-word;
  }

  .entry-title {
    font-family: var(--font-body);
    font-size: var(--text-md);
    font-weight: 500;
    color: var(--color-text);
    margin: var(--space-3) 0 var(--space-4);
    font-style: italic;
    overflow-wrap: break-word;
  }

  .entry-summary {
    font-size: var(--text-base);
    color: var(--color-text);
    max-width: 60ch;
    margin: 0 0 var(--space-4);
    overflow-wrap: break-word;
  }

  .entry-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-4);
    max-width: 60ch;
  }
  .entry-list li {
    display: grid;
    grid-template-columns: 16px minmax(0, 1fr);   /* minmax(0, 1fr) lets the column shrink */
    gap: var(--space-2);
    padding: 2px 0;
    font-size: var(--text-base);
    line-height: 1.55;
    overflow-wrap: break-word;
  }
  .entry-list .bullet {
    color: var(--color-subtle);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .entry-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: var(--space-3);
    min-width: 0;
  }

  /* Small tablet / large phone — --year-col-width and --timeline-column-gap already
     shrink via tokens.css. We just tighten in-column padding and company type. */
  @media (max-width: 640px) {
    .entry-content { padding-left: var(--space-3); }
    .entry-company { font-size: var(--text-lg); }
  }

  /* Phone — collapse the timeline entirely: year becomes a small label above, line + dot hidden.
     This releases the full viewport width back to the content and prevents overflow on narrow screens. */
  @media (max-width: 480px) {
    .entry {
      grid-template-columns: 1fr;
      column-gap: 0;
      padding-bottom: var(--space-7);
    }
    .entry-year {
      text-align: left;
      padding: 0 0 var(--space-2) 0;
      font-size: var(--text-xs);
    }
    .entry-dot { display: none; }
    .entry-content { padding-left: 0; }
    .entry--current .entry-company { color: var(--color-accent); }
  }
</style>
