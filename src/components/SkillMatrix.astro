---
import Badge from './Badge.astro';

interface Skills {
  programmiersprachen: string[]; frontend: string[]; backend: string[];
  devops: string[]; tools: string[]; vorgehensweisen: string[];
}
interface Props { skills: Skills; }
const { skills } = Astro.props;

const rows = [
  { label: 'Sprachen',         items: skills.programmiersprachen },
  { label: 'Frontend',         items: skills.frontend },
  { label: 'Backend',          items: skills.backend },
  { label: 'DevOps',           items: skills.devops },
  { label: 'Tools',            items: skills.tools },
  { label: 'Vorgehen',         items: skills.vorgehensweisen },
];
---
<div class="skill-grid">
  {rows.map(row => (
    <div class="skill-row">
      <div class="skill-row-label">{row.label}</div>
      <div class="skill-row-tags">
        {row.items.map(item => <Badge variant="default">{item}</Badge>)}
      </div>
    </div>
  ))}
</div>

<style>
  .skill-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .skill-row {
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr);
    column-gap: var(--space-5);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-rule);
  }
  .skill-row-tags { min-width: 0; }
  .skill-row:first-child { border-top: 0; padding-top: 0; }
  .skill-row-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding-top: 4px;
  }
  .skill-row-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  @media (max-width: 640px) {
    .skill-row { grid-template-columns: 1fr; gap: var(--space-2); }
  }
</style>
